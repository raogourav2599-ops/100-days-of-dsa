#include <stdio.h>
#include <stdlib.h>

// Tree Node
struct Node {
    int data;
    struct Node *left, *right;
};

// Queue Node
struct QNode {
    struct Node* node;
    int hd;
};

// Create Node
struct Node* newNode(int data) {
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp->data = data;
    temp->left = temp->right = NULL;
    return temp;
}

// Build Tree
struct Node* build(int arr[], int i, int n) {
    if (i >= n || arr[i] == -1) return NULL;

    struct Node* root = newNode(arr[i]);
    root->left = build(arr, 2*i+1, n);
    root->right = build(arr, 2*i+2, n);

    return root;
}

// Vertical Traversal
void vertical(struct Node* root) {
    struct QNode q[100];
    int front = 0, rear = 0;

    int map[200][100], count[200] = {0};

    q[rear++] = (struct QNode){root, 100};

    int min = 100, max = 100;

    while (front < rear) {
        struct QNode temp = q[front++];
        int hd = temp.hd;

        map[hd][count[hd]++] = temp.node->data;

        if (hd < min) min = hd;
        if (hd > max) max = hd;

        if (temp.node->left)
            q[rear++] = (struct QNode){temp.node->left, hd-1};

        if (temp.node->right)
            q[rear++] = (struct QNode){temp.node->right, hd+1};
    }

    for (int i = min; i <= max; i++) {
        for (int j = 0; j < count[i]; j++)
            printf("%d ", map[i][j]);
        printf("\n");
    }
}

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for (int i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    struct Node* root = build(arr, 0, n);

    vertical(root);

    return 0;
}
