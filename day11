# Input
m, n = map(int, input().split())

# First matrix
A = []
for i in range(m):
    row = list(map(int, input().split()))
    A.append(row)

# Second matrix
B = []
for i in range(m):
    row = list(map(int, input().split()))
    B.append(row)

# Result matrix
for i in range(m):
    for j in range(n):
        print(A[i][j] + B[i][j], end=" ")
    print()
