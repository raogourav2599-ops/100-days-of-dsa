#include <stdio.h>
#define MAX 100

int queue[MAX];
int front = 0, rear = -1, size = 0;

// Enqueue
void enqueue(int x) {
    if (size == MAX) {
        printf("Queue Overflow\n");
        return;
    }
    rear = (rear + 1) % MAX;
    queue[rear] = x;
    size++;
}

// Dequeue
void dequeue() {
    if (size == 0) {
        printf("Queue Underflow\n");
        return;
    }
    front = (front + 1) % MAX;
    size--;
}

// Display
void display() {
    if (size == 0) {
        printf("Queue is Empty");
        return;
    }

    int i = front;
    for (int count = 0; count < size; count++) {
        printf("%d ", queue[i]);
        i = (i + 1) % MAX;
    }
}

int main() {
    int n, m, x;

    scanf("%d", &n);

    // Enqueue n elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &x);
        enqueue(x);
    }

    scanf("%d", &m);

    // Dequeue m times
    for (int i = 0; i < m; i++) {
        dequeue();
    }

    display();

    return 0;
}
