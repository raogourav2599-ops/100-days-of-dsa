#include <stdio.h>

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    int graph[n][n];

    // Initialize matrix with 0
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            graph[i][j] = 0;

    int type;
    printf("Enter 0 for Undirected, 1 for Directed: ");
    scanf("%d", &type);

    // Input edges
    for (int i = 0; i < m; i++) {
        int u, v;
        scanf("%d %d", &u, &v);

        graph[u][v] = 1;

        if (type == 0) {
            graph[v][u] = 1;
        }
    }

    // Print matrix
    printf("Adjacency Matrix:\n");

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            printf("%d ", graph[i][j]);
        }
        printf("\n");
    }

    return 0;
}
