#include <stdio.h>
#include <string.h>

#define MAX 1000
#define NAME_LEN 50

struct Candidate {
    char name[NAME_LEN];
    int count;
};

int main() {
    int n;
    scanf("%d", &n);

    struct Candidate arr[MAX];
    int size = 0;

    for (int i = 0; i < n; i++) {
        char name[NAME_LEN];
        scanf("%s", name);

        int found = -1;

        // Check if candidate already exists
        for (int j = 0; j < size; j++) {
            if (strcmp(arr[j].name, name) == 0) {
                found = j;
                break;
            }
        }

        if (found != -1) {
            arr[found].count++;
        } else {
            strcpy(arr[size].name, name);
            arr[size].count = 1;
            size++;
        }
    }

    // Find winner
    char winner[NAME_LEN];
    int maxVotes = 0;

    for (int i = 0; i < size; i++) {
        if (arr[i].count > maxVotes) {
            maxVotes = arr[i].count;
            strcpy(winner, arr[i].name);
        }
        else if (arr[i].count == maxVotes) {
            if (strcmp(arr[i].name, winner) < 0) {
                strcpy(winner, arr[i].name);
            }
        }
    }

    printf("%s %d\n", winner, maxVotes);

    return 0;
}
