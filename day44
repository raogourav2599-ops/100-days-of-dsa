from collections import deque

class Node:
    def __init__(self, val):
        self.data = val
        self.left = None
        self.right = None

def build_tree(arr, n):
    if n == 0 or arr[0] == -1:
        return None

    root = Node(arr[0])
    q = deque([root])
    i = 1

    while q and i < n:
        current = q.popleft()

        # left child
        if i < n and arr[i] != -1:
            current.left = Node(arr[i])
            q.append(current.left)
        i += 1

        # right child
        if i < n and arr[i] != -1:
            current.right = Node(arr[i])
            q.append(current.right)
        i += 1

    return root

# Traversals
def inorder(root):
    if root:
        inorder(root.left)
        print(root.data, end=" ")
        inorder(root.right)

def preorder(root):
    if root:
        print(root.data, end=" ")
        preorder(root.left)
        preorder(root.right)

def postorder(root):
    if root:
        postorder(root.left)
        postorder(root.right)
        print(root.data, end=" ")

# Input
n = int(input())
arr = list(map(int, input().split()))

root = build_tree(arr, n)

# Output
inorder(root)
print()
preorder(root)
print()
postorder(root)
