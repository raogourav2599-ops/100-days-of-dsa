from collections import deque

class Node:
    def __init__(self, val):
        self.data = val
        self.left = None
        self.right = None

def build_tree(arr, n):
    if n == 0 or arr[0] == -1:
        return None

    root = Node(arr[0])
    q = deque([root])
    i = 1

    while q and i < n:
        current = q.popleft()

        if i < n and arr[i] != -1:
            current.left = Node(arr[i])
            q.append(current.left)
        i += 1

        if i < n and arr[i] != -1:
            current.right = Node(arr[i])
            q.append(current.right)
        i += 1

    return root

def level_order(root):
    if root is None:
        return

    q = deque([root])

    while q:
        node = q.popleft()
        print(node.data, end=" ")

        if node.left:
            q.append(node.left)
        if node.right:
            q.append(node.right)

# Input
n = int(input())
arr = list(map(int, input().split()))

root = build_tree(arr, n)

# Output
level_order(root)
