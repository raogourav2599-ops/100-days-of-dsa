# Input
m, n = map(int, input().split())

matrix = []
for i in range(m):
    row = list(map(int, input().split()))
    matrix.append(row)

# Check if square
if m != n:
    print("Not a Symmetric Matrix")
else:
    is_symmetric = True

    for i in range(m):
        for j in range(n):
            if matrix[i][j] != matrix[j][i]:
                is_symmetric = False
                break
        if not is_symmetric:
            break

    if is_symmetric:
        print("Symmetric Matrix")
    else:
        print("Not a Symmetric Matrix")
