#include <stdio.h>

int integerSqrt(int n) {
    int low = 0, high = n;
    int ans = 0;

    while (low <= high) {
        int mid = (low + high) / 2;

        // To avoid overflow, use mid <= n/mid instead of mid*mid <= n
        if (mid <= n / mid) {
            ans = mid;        // possible answer
            low = mid + 1;    // move right
        } else {
            high = mid - 1;   // move left
        }
    }
    return ans;
}

int main() {
    int n;
    scanf("%d", &n);

    printf("%d", integerSqrt(n));

    return 0;
}
