n = int(input())
pq = []

for _ in range(n):
    op = input().split()
    
    if op[0] == "insert":
        pq.append(int(op[1]))
    
    elif op[0] == "delete":
        if len(pq) == 0:
            print(-1)
        else:
            min_val = min(pq)
            pq.remove(min_val)
            print(min_val)
    
    elif op[0] == "peek":
        if len(pq) == 0:
            print(-1)
        else:
            print(min(pq))
