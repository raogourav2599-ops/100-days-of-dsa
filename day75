#include <stdio.h>

#define MAX 1000

int main() {
    int n;
    scanf("%d", &n);

    int arr[MAX];
    for (int i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    int prefixSum = 0;
    int maxLen = 0;

    // Simple hashmap using array (for demo)
    int map[10000];
    for (int i = 0; i < 10000; i++)
        map[i] = -2;  // -2 means not visited

    for (int i = 0; i < n; i++) {
        prefixSum += arr[i];

        if (prefixSum == 0) {
            maxLen = i + 1;
        }

        int index = prefixSum + 5000; // shift to avoid negative index

        if (map[index] == -2) {
            map[index] = i;
        } else {
            int len = i - map[index];
            if (len > maxLen)
                maxLen = len;
        }
    }

    printf("%d\n", maxLen);

    return 0;
}
