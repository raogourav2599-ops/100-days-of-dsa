# Input
n = int(input())
arr = list(map(int, input().split()))

# Dictionary to store prefix sum frequency
freq = {0: 1}   # important (for sum=0 from start)
prefix_sum = 0
count = 0

for num in arr:
    prefix_sum += num

    if prefix_sum in freq:
        count += freq[prefix_sum]

    freq[prefix_sum] = freq.get(prefix_sum, 0) + 1

# Output
print(count)
