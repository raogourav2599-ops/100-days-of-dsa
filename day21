# Node class
class Node:
    def __init__(self, data):
        self.data = data
        self.next = None

# Create linked list
def create_list(arr):
    head = Node(arr[0])
    current = head

    for i in range(1, len(arr)):
        current.next = Node(arr[i])
        current = current.next

    return head

# Traverse and print
def traverse(head):
    temp = head
    while temp:
        print(temp.data, end=" ")
        temp = temp.next

# Input
n = int(input())
arr = list(map(int, input().split()))

# Create and print
head = create_list(arr)
traverse(head)
      
